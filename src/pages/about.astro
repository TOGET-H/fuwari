---
import ImageWrapper from "@components/misc/ImageWrapper.astro";
import { Icon } from "astro-icon/components";
import { profileConfig } from "../config";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";
import MainGridLayout from "../layouts/MainGridLayout.astro";

const highlights = [
	{ value: "CS", label: "计算机方向", note: "持续补齐基础与工程能力" },
	{ value: "FE", label: "前端开发", note: "把想法做成真实可用的产品" },
	{ value: "AI", label: "智能应用", note: "关注 AI 与业务场景结合" },
];

const qualities = [
	{
		icon: "material-symbols:wb-sunny-outline-rounded",
		title: "阳光主动",
		desc: "遇到问题先拆解、再验证，把复杂任务一步一步推进到可落地的结果。",
	},
	{
		icon: "material-symbols:trending-up-rounded",
		title: "长期上进",
		desc: "每天给自己留出固定时间学习、复盘和输出，让能力增长有痕迹。",
	},
	{
		icon: "material-symbols:construction-rounded",
		title: "动手能力",
		desc: "喜欢通过项目学习技术，从需求、页面、接口到部署都尽量亲自跑通。",
	},
	{
		icon: "material-symbols:groups-outline-rounded",
		title: "开放协作",
		desc: "愿意沟通、记录和分享，也重视和优秀的人一起把事情做扎实。",
	},
];

const timeline = [
	{
		time: "现在",
		title: "计算机研究生在读",
		desc: "围绕前端工程、AI 应用和系统能力持续训练，努力把每一次学习都沉淀成作品。",
	},
	{
		time: "正在做",
		title: "全栈开发目标",
		desc: "从前端体验出发，逐步补齐后端、数据库、工程化和部署能力。",
	},
	{
		time: "曾经",
		title: "电工背景",
		desc: "带着工程现场的务实习惯进入软件开发，重视可靠性、细节和问题闭环。",
	},
	{
		time: "长期",
		title: "保持热爱",
		desc: "喜欢技术、摄影和记录生活，希望成为一个可靠、明亮、持续成长的人。",
	},
];

const focusList = [
	"前端基础",
	"Vue / JS",
	"Node.js",
	"工程化",
	"AI 应用",
	"项目复盘",
];
const stackList = ["Java", "Vue", "TypeScript", "Node.js", "Python", "AI App"];
---

<MainGridLayout title={i18n(I18nKey.about)} description="关于我">
	<section class="about-tech-bg card-base relative mb-4 overflow-hidden">
		<div class="tech-grid" aria-hidden="true"></div>
		<div class="tech-scanline" aria-hidden="true"></div>

		<div class="relative z-10 grid gap-7 px-6 py-7 md:grid-cols-[1fr_18rem] md:px-9 md:py-9">
			<div class="min-w-0">
				<div class="mb-5 flex flex-wrap items-center gap-2">
					<span class="inline-flex items-center gap-2 rounded-md border border-black/10 bg-white/70 px-3 py-1.5 text-sm font-medium text-[var(--primary)] backdrop-blur dark:border-white/10 dark:bg-white/[0.06]">
						<Icon name="material-symbols:bolt-rounded" class="text-lg" />
						保持学习，持续进步
					</span>
					<span class="rounded-md border border-black/10 bg-white/50 px-3 py-1.5 font-mono text-xs text-50 dark:border-white/10 dark:bg-white/[0.04]">
						status: building
					</span>
				</div>

				<h1 class="mb-4 max-w-2xl text-3xl font-bold leading-tight text-90 md:text-5xl">
					你好，我是{profileConfig.name}
				</h1>
				<p class="max-w-2xl text-base leading-8 text-75 md:text-lg">
					一名正在成长中的计算机研究生。目标是成为能独立解决问题的全栈开发者：
					写得出清晰的页面，也理解背后的系统；做得出可运行的项目，也愿意长期打磨基本功。
				</p>

				<div class="mt-6 flex flex-wrap gap-2">
					{focusList.map((item) => (
						<span class="rounded-md border border-black/10 bg-white/60 px-3 py-1.5 text-sm font-medium text-black/70 backdrop-blur transition dark:border-white/10 dark:bg-white/[0.06] dark:text-white/70">
							{item}
						</span>
					))}
				</div>
			</div>

			<aside class="tech-console self-stretch rounded-lg border border-black/10 bg-white/75 p-4 shadow-sm backdrop-blur dark:border-white/10 dark:bg-black/20">
				<div class="mb-4 flex items-center justify-between border-b border-black/10 pb-3 dark:border-white/10">
					<div class="flex gap-1.5" aria-hidden="true">
						<span class="h-2.5 w-2.5 rounded-full bg-[oklch(0.68_0.18_25)]"></span>
						<span class="h-2.5 w-2.5 rounded-full bg-[oklch(0.78_0.16_80)]"></span>
						<span class="h-2.5 w-2.5 rounded-full bg-[oklch(0.72_0.15_155)]"></span>
					</div>
					<span class="font-mono text-xs text-50">profile.ts</span>
				</div>

				<div class="mb-4 flex items-center gap-4">
					<div class="h-20 w-20 shrink-0 overflow-hidden rounded-lg border border-black/10 bg-black/5 dark:border-white/10 dark:bg-white/10">
						<ImageWrapper
							src={profileConfig.avatar || ""}
							alt="Profile image"
							class="h-full w-full object-cover"
						/>
					</div>
					<div class="min-w-0">
						<div class="truncate text-lg font-bold text-90">{profileConfig.name}</div>
						<div class="mt-1 font-mono text-xs text-50">role: student_developer</div>
					</div>
				</div>

				<div class="space-y-2 font-mono text-xs leading-6 text-75">
					<div><span class="text-[var(--primary)]">const</span> goal = "Full-stack Developer";</div>
					<div><span class="text-[var(--primary)]">const</span> mode = "learn · build · review";</div>
					<div><span class="text-[var(--primary)]">const</span> attitude = "sunny and reliable";</div>
				</div>
			</aside>
		</div>
	</section>

	<section class="mb-4 grid gap-4 md:grid-cols-3">
		{highlights.map((item) => (
			<div class="card-base border border-black/[0.03] px-6 py-5 dark:border-white/[0.05]">
				<div class="mb-2 font-mono text-3xl font-bold text-[var(--primary)]">{item.value}</div>
				<div class="mb-1 font-bold text-90">{item.label}</div>
				<div class="text-sm leading-6 text-75">{item.note}</div>
			</div>
		))}
	</section>

	<section class="card-base mb-4 overflow-hidden">
		<div class="border-b border-dashed border-black/10 px-6 py-4 dark:border-white/10 md:px-9">
			<div class="flex items-center gap-3">
				<Icon name="material-symbols:terminal-rounded" class="text-2xl text-[var(--primary)]" />
				<h2 class="text-xl font-bold text-90">技术栈与关注方向</h2>
			</div>
		</div>
		<div class="grid gap-3 px-6 py-5 md:grid-cols-3 md:px-9">
			{stackList.map((item) => (
				<div class="flex items-center justify-between rounded-md border border-black/10 bg-black/[0.02] px-4 py-3 dark:border-white/10 dark:bg-white/[0.04]">
					<span class="font-medium text-75">{item}</span>
					<span class="h-2 w-2 rounded-full bg-[oklch(0.72_0.15_155)]"></span>
				</div>
			))}
		</div>
	</section>

	<section class="mb-4 grid gap-4 md:grid-cols-2">
		{qualities.map((item) => (
			<div class="card-base border border-black/[0.03] px-6 py-5 dark:border-white/[0.05]">
				<div class="mb-4 flex h-11 w-11 items-center justify-center rounded-lg bg-[oklch(0.95_0.03_var(--hue))] text-[var(--primary)] dark:bg-white/10">
					<Icon name={item.icon} class="text-2xl" />
				</div>
				<h2 class="mb-2 text-xl font-bold text-90">{item.title}</h2>
				<p class="leading-7 text-75">{item.desc}</p>
			</div>
		))}
	</section>

	<section class="card-base mb-4 px-6 py-6 md:px-9">
		<div class="mb-5 flex items-center gap-3">
			<div class="h-10 w-1 rounded-full bg-[var(--primary)]"></div>
			<div>
				<h2 class="text-2xl font-bold text-90">成长轨迹</h2>
				<p class="mt-1 text-sm text-75">把努力变成每天都能看见的进度。</p>
			</div>
		</div>

		<div class="space-y-5">
			{timeline.map((item) => (
				<div class="grid gap-3 border-l border-dashed border-black/10 pl-5 dark:border-white/15 md:grid-cols-[5rem_auto] md:border-l-0 md:pl-0">
					<div class="font-mono text-sm font-bold text-[var(--primary)]">{item.time}</div>
					<div>
						<div class="mb-1 font-bold text-90">{item.title}</div>
						<div class="leading-7 text-75">{item.desc}</div>
					</div>
				</div>
			))}
		</div>
	</section>

	<section class="card-base px-6 py-6 md:px-9">
		<div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
			<div>
				<h2 class="mb-2 text-2xl font-bold text-90">我的状态</h2>
				<p class="max-w-2xl leading-7 text-75">
					认真学习，认真做项目，认真生活。希望每一次打开博客，都能看到比昨天更清楚的思考、
					更扎实的代码和更坚定的方向。
				</p>
			</div>
			<div class="flex shrink-0 items-center gap-2 rounded-lg border border-black/10 bg-black/[0.04] px-4 py-3 font-bold text-[var(--primary)] dark:border-white/10 dark:bg-white/[0.08]">
				<Icon name="material-symbols:rocket-launch-outline-rounded" class="text-2xl" />
				<span>向前走，别停下</span>
			</div>
		</div>
	</section>
</MainGridLayout>

<style>
	.about-tech-bg {
		background:
			linear-gradient(135deg, rgba(255, 255, 255, 0.88), rgba(255, 255, 255, 0.72)),
			var(--card-bg);
	}

	:global(.dark) .about-tech-bg {
		background:
			linear-gradient(135deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0.015)),
			var(--card-bg);
	}

	.tech-grid {
		position: absolute;
		inset: 0;
		background-image:
			linear-gradient(to right, rgba(0, 0, 0, 0.07) 1px, transparent 1px),
			linear-gradient(to bottom, rgba(0, 0, 0, 0.07) 1px, transparent 1px);
		background-size: 28px 28px;
		mask-image: linear-gradient(to bottom right, black, transparent 78%);
		opacity: 0.42;
	}

	:global(.dark) .tech-grid {
		background-image:
			linear-gradient(to right, rgba(255, 255, 255, 0.08) 1px, transparent 1px),
			linear-gradient(to bottom, rgba(255, 255, 255, 0.08) 1px, transparent 1px);
		opacity: 0.34;
	}

	.tech-scanline {
		position: absolute;
		inset: 0;
		background: repeating-linear-gradient(
			to bottom,
			transparent,
			transparent 9px,
			rgba(0, 0, 0, 0.035) 10px
		);
		opacity: 0.24;
		pointer-events: none;
	}

	:global(.dark) .tech-scanline {
		background: repeating-linear-gradient(
			to bottom,
			transparent,
			transparent 9px,
			rgba(255, 255, 255, 0.04) 10px
		);
	}
</style>
